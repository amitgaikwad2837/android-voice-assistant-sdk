#!/bin/sh
#
# Gradle start up script for UN*X
#
dir=dirname "pwd/asename "
APP_HOME=dirname ""
APP_NAME="Gradle"
APP_BASE_NAME=asename "" .sh
CLASSPATH=`
JAVACMD=which java
if [ -z "$JAVACMD" ] ; then
  JAVA_HOME=which java
fi
exec "$JAVACMD" "$@"" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
